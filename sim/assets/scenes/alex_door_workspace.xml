<mujoco model="alex_door_workspace">
    <!-- Alex upper-body scene with a simple articulated door task object. -->

    <compiler meshdir="../robots/alex/" angle="radian" balanceinertia="true" autolimits="true"/>

    <include file="../robots/alex/alex.xml"/>

    <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast"
            cone="pyramidal" solver="Newton" iterations="80" ls_iterations="10">
        <flag energy="enable"/>
    </option>

    <default>
        <default class="door/contact">
            <geom contype="1" conaffinity="1" solref="0.006 1.0"
                  solimp="0.9 0.95 0.001 0.5 2" friction="0.8 0.01 0.005"
                  condim="4"/>
        </default>
        <default class="door/visual">
            <geom contype="0" conaffinity="0" group="0"/>
        </default>
    </default>

    <statistic center="0.55 0 1.0" extent="1.5"/>

    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
        <rgba haze="0.15 0.25 0.35 1"/>
        <global azimuth="120" elevation="-20" offwidth="1280" offheight="720"/>
    </visual>

    <asset>
        <texture type="2d" name="groundplane" builtin="checker"
                 rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
                 width="300" height="300"/>
        <material name="groundplane" texture="groundplane" texuniform="true"
                  texrepeat="5 5"/>
        <material name="door_panel_mat" rgba="0.56 0.46 0.34 1"/>
        <material name="door_handle_mat" rgba="0.72 0.70 0.62 1"/>
        <material name="frame_mat" rgba="0.22 0.24 0.25 1"/>
    </asset>

    <worldbody>
        <light pos="0 0 3" dir="0 0 -1" directional="true"/>
        <camera name="overhead" pos="0.55 -2.4 2.6"
                xyaxes="1 0 0 0 0.72 0.69" fovy="58"/>
        <camera name="third_person" pos="1.65 -1.25 1.55"
                xyaxes="0.59 0.81 0 -0.25 0.18 0.95" fovy="55"/>
        <camera name="handle_closeup" pos="0.95 -0.85 1.18"
                xyaxes="0.77 0.64 0 -0.17 0.20 0.97" fovy="42"/>

        <geom name="floor" type="plane" size="0 0 0.05" material="groundplane"
              contype="1" conaffinity="1" priority="1" friction="0.8" condim="3"/>

        <body name="door_frame" pos="0.58 -0.25 1.02">
            <geom class="door/contact" name="door_hinge_post" type="box"
                  size="0.025 0.025 0.58" pos="0 0 0" material="frame_mat"/>
            <geom class="door/contact" name="door_lintel" type="box"
                  size="0.025 0.31 0.025" pos="0 0.28 0.555" material="frame_mat"/>
            <geom class="door/contact" name="door_threshold" type="box"
                  size="0.025 0.31 0.015" pos="0 0.28 -0.505" material="frame_mat"/>
        </body>

        <body name="hinged_door" pos="0.58 -0.25 1.02">
            <joint name="door_hinge" type="hinge" axis="0 0 1"
                   range="-0.05 1.5708" limited="true" damping="2.0" armature="0.02"/>
            <geom class="door/contact" name="door_panel" type="box"
                  size="0.018 0.26 0.48" pos="0 0.26 0"
                  material="door_panel_mat" mass="8"/>
            <geom class="door/contact" name="door_handle_mount" type="sphere"
                  size="0.025" pos="-0.035 0.405 0.035"
                  material="door_handle_mat" mass="0.1"/>
            <geom class="door/contact" name="door_handle" type="capsule"
                  fromto="-0.035 0.42 0.035 -0.035 0.54 0.035"
                  size="0.014" material="door_handle_mat" mass="0.15"/>
            <site name="door_handle_site" pos="-0.035 0.48 0.035"
                  size="0.025" rgba="0.2 0.7 1.0 0.35"/>
        </body>
    </worldbody>

    <actuator>
        <motor name="door_hinge_motor" joint="door_hinge" gear="1" ctrlrange="-2 2"/>
    </actuator>

    <sensor>
        <jointpos name="door_angle" joint="door_hinge"/>
        <jointvel name="door_angular_velocity" joint="door_hinge"/>
        <touch name="handle_touch" site="door_handle_site"/>
    </sensor>
</mujoco>
